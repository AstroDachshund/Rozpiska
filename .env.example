# Rozpiska — zmienne środowiskowe. Skopiuj do `.env.local` (aplikacja) / `.env.test.local` (testy RLS).
# Wartości lokalne pobierzesz z `supabase status -o env` po `npm run db:start`.

# Klient przeglądarki (bundlowane do frontu — tylko klucze publiczne!)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Testy RLS (Vitest, Node — service_role NIGDY nie trafia do bundla klienta)
SUPABASE_URL=http://127.0.0.1:54321
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
